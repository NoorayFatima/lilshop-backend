# Backend Environment Variables Example
# Copy this file to .env.local and fill in the values for your environment

# Database Configuration (REQUIRED)
# Get this from Supabase or your Postgres provider
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres

# JWT & Cookie Secrets (REQUIRED)
# Generate strong random strings for production (min 32 chars)
JWT_SECRET=your_very_long_random_jwt_secret_here_at_least_32_chars
COOKIE_SECRET=your_very_long_random_cookie_secret_here_at_least_32_chars

# CORS Configuration (REQUIRED)
# Set these to your deployed frontend and Medusa admin URLs
STORE_CORS=http://localhost:8000,https://your-frontend-domain.com
ADMIN_CORS=http://localhost:5173,https://your-medusa-admin-domain.com
AUTH_CORS=http://localhost:5173,https://your-medusa-admin-domain.com

# Redis URL (OPTIONAL but recommended for production)
# If using Upstash or similar free Redis service
REDIS_URL=redis://default:your-redis-password@your-redis-host:6379

# Node Environment
NODE_ENV=production

# Email Configuration (OPTIONAL - for order confirmations, password resets)
# SendGrid API Key - https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# WhatsApp Integration (OPTIONAL)
# For automated WhatsApp messages via Twilio (requires paid API after free trial)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+1234567890

# Stripe Configuration (OPTIONAL - if using Stripe for payments)
# STRIPE_API_KEY=sk_live_your_stripe_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Database Name (Optional, some frameworks use this)
DB_NAME=medusa

# Admin Email for initial setup (OPTIONAL)
# MEDUSA_ADMIN_EMAIL=admin@example.com
# MEDUSA_ADMIN_PASSWORD=securepassword
